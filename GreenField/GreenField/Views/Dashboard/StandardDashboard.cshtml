@model GreenField.Models.ViewModels.StandardDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var displayName = Model.UserName.Contains("@") ? Model.UserName.Split('@')[0] : Model.UserName;
    displayName = char.ToUpper(displayName[0]) + displayName.Substring(1);
}

@Html.AntiForgeryToken()
<div class="dashboard-wrap">

    <div class="dash-header">
        <div>
            <h1 class="dash-title">Dashboard</h1>
            <p class="dash-subtitle">Welcome back, @displayName. Here's your account overview.</p>
        </div>
        <form asp-area="Identity" asp-page="/Account/Logout" method="post" style="margin:0;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-logout">
                <i class="bi bi-box-arrow-right"></i> Log Out
            </button>
        </form>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="stat-cards">
        <div class="stat-card">
            <div class="stat-card-icon-wrap">
                <i class="bi bi-person-fill"></i>
            </div>
            <div class="stat-card-body">
                <p class="stat-card-name">@displayName</p>
                <p class="stat-card-meta">Member since @DateTime.Now.Year</p>
                <p class="stat-card-detail"><strong>Email:</strong> @Model.Email</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon-wrap points-icon">
                <i class="bi bi-coin"></i>
            </div>
            <div class="stat-card-body">
                <p class="stat-card-label">Points Balance</p>
                <p class="stat-card-big">@Model.Points</p>
                <div class="stars">
                    @for (int i = 0; i < 5; i++)
                    {
                        <i class="bi bi-star-fill @(i < Math.Min(5, Model.Points / 50) ? "star-on" : "star-off")"></i>
                    }
                </div>
                <span class="next-reward-badge">@Model.PointsToNextReward points to next reward</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon-wrap orders-icon">
                <i class="bi bi-box-seam-fill"></i>
            </div>
            <div class="stat-card-body">
                <p class="stat-card-label">Total Orders</p>
                <p class="stat-card-big">@Model.Orders.Count</p>
                @{
                    var allDelivered = Model.Orders.All(o => o.Status == GreenField.Models.OrderStatus.Delivered || o.Status == GreenField.Models.OrderStatus.Collected);
                }
                <p class="stat-card-meta">@(allDelivered && Model.Orders.Any() ? "All orders delivered" : $"{Model.Orders.Count(o => o.Status == GreenField.Models.OrderStatus.Pending || o.Status == GreenField.Models.OrderStatus.Processing)} active")</p>
            </div>
        </div>
    </div>

    <div class="dash-tabs">
        <button class="dash-tab active" data-tab="orders">Order History</button>
        <button class="dash-tab" data-tab="profile">My Profile</button>
        <a asp-controller="LoyaltyPoints" asp-action="Index" class="dash-tab">Points & Rewards</a>
    </div>

    <div class="dash-panel active" id="tab-orders">
        <div class="panel-card">
            <h2 class="panel-heading">Order History</h2>
            @if (!Model.Orders.Any())
            {
                <p class="empty-state">You haven't placed any orders yet.</p>
            }
            else
            {
                <div class="order-list">
                    @foreach (var order in Model.Orders)
                    {
                        var statusClass = order.Status switch
                        {
                            GreenField.Models.OrderStatus.Delivered => "badge-delivered",
                            GreenField.Models.OrderStatus.Collected => "badge-collected",
                            GreenField.Models.OrderStatus.Processing => "badge-processing",
                            GreenField.Models.OrderStatus.Cancelled => "badge-cancelled",
                            _ => "badge-pending"
                        };
                        <div class="order-row-block">
                            <div class="order-row-top order-toggle" onclick="toggleOrder('std-@order.OrdersId')" style="cursor:pointer;">
                                <div class="order-row-left">
                                    <p class="order-id">ORD-@order.OrdersId.ToString("D4")</p>
                                    <p class="order-meta">
                                        @order.OrderDate.ToString("MMMM d, yyyy") &middot;
                                        @order.OrderProducts.Count item@(order.OrderProducts.Count != 1 ? "s" : "") &middot;
                                        @(order.IsDelivery ? "Delivery" : "Click & Collect")
                                    </p>
                                </div>
                                <div class="order-row-right">
                                    <span class="status-badge @statusClass">@order.Status</span>
                                    <span class="order-price">£@order.TotalPrice.ToString("F2")</span>
                                    <i class="bi bi-chevron-down order-chevron order-chevron-icon" id="chevron-std-@order.OrdersId"></i>
                                </div>
                            </div>

                            <div class="order-detail-panel" id="std-@order.OrdersId" style="display:none;">
                                <table class="table order-detail-table">
                                    <thead>
                                        <tr>
                                            <th>Product</th>
                                            <th style="text-align:center;">Qty</th>
                                            <th style="text-align:right;">Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var op in order.OrderProducts ?? new List<GreenField.Models.OrderProducts>())
                                        {
                                            <tr>
                                                <td>@op.Products?.ProductName</td>
                                                <td style="text-align:center;">@op.Quantity</td>
                                                <td style="text-align:right;">£@(((op.Products?.Price ?? 0) * op.Quantity).ToString("F2"))</td>
                                            </tr>
                                        }
                                        @if (order.DeliveryFee > 0)
                                        {
                                            <tr>
                                                <td colspan="2" class="text-muted">Delivery Fee</td>
                                                <td style="text-align:right;">£@order.DeliveryFee.ToString("F2")</td>
                                            </tr>
                                        }
                                        @if (order.UsedDiscount && !string.IsNullOrEmpty(order.DiscountName))
                                        {
                                            <tr>
                                                <td colspan="2" class="text-green">Discount (@order.DiscountName)</td>
                                                <td style="text-align:right;" class="discount-amount">Applied</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="2" class="bold">Total</td>
                                            <td style="text-align:right;" class="bold">£@order.TotalPrice.ToString("F2")</td>
                                        </tr>
                                    </tfoot>
                                </table>

                                <div class="order-detail-meta">
                                    @if (order.IsDelivery)
                                    {
                                        <p><i class="bi bi-geo-alt-fill"></i> Delivering to: <strong>@order.DeliveryAddress</strong></p>
                                    }
                                    else
                                    {
                                        <p><i class="bi bi-shop"></i> Click &amp; Collect
                                            @if (order.CollectionDate.HasValue)
                                            {
                                                <span>&mdash; @order.CollectionDate.Value.ToString("d MMM yyyy")</span>
                                            }
                                        </p>
                                    }
                                </div>

                                @if (order.Status == GreenField.Models.OrderStatus.Pending)
                                {
                                    <div class="order-detail-actions" id="cancel-wrap-@order.OrdersId">
                                        <button class="btn-cancel"
                                                onclick="cancelOrder(@order.OrdersId, this)">
                                            <i class="bi bi-x-circle"></i> Cancel Order
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="dash-panel" id="tab-points">
        <div class="panel-card">
            <h2 class="panel-heading">Points & Rewards</h2>
            <div class="points-summary">
                <div class="points-stat">
                    <p class="points-stat-label">Current Balance</p>
                    <p class="points-stat-value">@Model.Points pts</p>
                </div>
                <div class="points-stat">
                    <p class="points-stat-label">Points to Next Reward</p>
                    <p class="points-stat-value">@Model.PointsToNextReward pts</p>
                </div>
            </div>
            <div class="points-history">
                @foreach (var order in Model.Orders.Where(o => o.Status != GreenField.Models.OrderStatus.Cancelled))
                {
                    int earned = (int)(order.OrderProducts.Sum(op => (op.Products?.Price ?? 0) * op.Quantity) * 10);
                    <div class="points-row">
                        <span class="points-row-label">ORD-@order.OrdersId.ToString("D4") — @order.OrderProducts.Count item@(order.OrderProducts.Count != 1 ? "s" : "")</span>
                        <span class="points-earned">+@earned pts</span>
                    </div>
                }
                <div class="points-row">
                    <span class="points-row-label">Welcome bonus</span>
                    <span class="points-earned">+50 pts</span>
                </div>
            </div>
        </div>
    </div>


</div>

<script>
    document.querySelectorAll('.dash-tab').forEach(tab => {
        tab.addEventListener('click', () => {
            document.querySelectorAll('.dash-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.dash-panel').forEach(p => p.classList.remove('active'));
            tab.classList.add('active');
            document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
        });
    });

    function toggleOrder(id) {
        const panel = document.getElementById(id);
        const chevron = document.getElementById('chevron-' + id);
        const isOpen = panel.style.display !== 'none';
        panel.style.display = isOpen ? 'none' : 'block';
        if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
    }

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    async function cancelOrder(orderId, btn) {
        if (!confirm('Are you sure you want to cancel this order?')) return;
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Cancelling…';

        const res = await fetch('/Orders/CancelAjax', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: `orderId=${orderId}`
        });

        if (res.ok) {
            const data = await res.json();
            if (data.success) {
                // Update badge
                const row = btn.closest('.order-row-block');
                const badge = row.querySelector('.status-badge');
                if (badge) {
                    badge.textContent = 'Cancelled';
                    badge.className = 'status-badge badge-cancelled';
                }
                // Remove cancel button wrap
                document.getElementById('cancel-wrap-' + orderId)?.remove();
            }
        } else {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-x-circle"></i> Cancel Order';
            alert('Could not cancel the order. Please try again.');
        }
    }
</script>