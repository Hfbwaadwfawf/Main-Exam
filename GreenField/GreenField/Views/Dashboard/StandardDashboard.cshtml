@model GreenField.Models.ViewModels.StandardDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var displayName = Model.UserName.Contains("@") ? Model.UserName.Split('@')[0] : Model.UserName;
    displayName = char.ToUpper(displayName[0]) + displayName.Substring(1);
}

<div class="dashboard-wrap">

    <div class="dash-header">
        <div>
            <h1 class="dash-title">Dashboard</h1>
            <p class="dash-subtitle">Welcome back, @displayName. Here's your account overview.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="stat-cards">
        <div class="stat-card">
            <div class="stat-card-icon-wrap">
                <i class="bi bi-person-fill"></i>
            </div>
            <div class="stat-card-body">
                <p class="stat-card-name">@displayName</p>
                <p class="stat-card-meta">Member since @DateTime.Now.Year</p>
                <p class="stat-card-detail"><strong>Email:</strong> @Model.Email</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon-wrap points-icon">
                <i class="bi bi-coin"></i>
            </div>
            <div class="stat-card-body">
                <p class="stat-card-label">Points Balance</p>
                <p class="stat-card-big">@Model.Points</p>
                <div class="stars">
                    @for (int i = 0; i < 5; i++)
                    {
                        <i class="bi bi-star-fill @(i < Math.Min(5, Model.Points / 50) ? "star-on" : "star-off")"></i>
                    }
                </div>
                <span class="next-reward-badge">@Model.PointsToNextReward points to next reward</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon-wrap orders-icon">
                <i class="bi bi-box-seam-fill"></i>
            </div>
            <div class="stat-card-body">
                <p class="stat-card-label">Total Orders</p>
                <p class="stat-card-big">@Model.Orders.Count</p>
                @{
                    var allDelivered = Model.Orders.All(o => o.Status == GreenField.Models.OrderStatus.Delivered || o.Status == GreenField.Models.OrderStatus.Collected);
                }
                <p class="stat-card-meta">@(allDelivered && Model.Orders.Any() ? "All orders delivered" : $"{Model.Orders.Count(o => o.Status == GreenField.Models.OrderStatus.Pending || o.Status == GreenField.Models.OrderStatus.Processing)} active")</p>
            </div>
        </div>
    </div>

    <div class="dash-tabs">
        <button class="dash-tab active" data-tab="orders">Order History</button>
        <button class="dash-tab" data-tab="profile">My Profile</button>
        <button class="dash-tab" data-tab="points">Points & Rewards</button>
    </div>

    <div class="dash-panel active" id="tab-orders">
        <div class="panel-card">
            <h2 class="panel-heading">Order History</h2>
            @if (!Model.Orders.Any())
            {
                <p class="empty-state">You haven't placed any orders yet.</p>
            }
            else
            {
                <div class="order-list">
                    @foreach (var order in Model.Orders)
                    {
                        var statusClass = order.Status switch
                        {
                            GreenField.Models.OrderStatus.Delivered => "badge-delivered",
                            GreenField.Models.OrderStatus.Collected => "badge-collected",
                            GreenField.Models.OrderStatus.Processing => "badge-processing",
                            GreenField.Models.OrderStatus.Cancelled => "badge-cancelled",
                            _ => "badge-pending"
                        };
                        <a href="/Orders/Details/@order.OrdersId" class="order-row">
                            <div class="order-row-left">
                                <p class="order-id">ORD-@order.OrdersId.ToString("D4")</p>
                                <p class="order-meta">
                                    @order.OrderDate.ToString("MMMM d, yyyy") &middot;
                                    @order.OrderProducts.Count item@(order.OrderProducts.Count != 1 ? "s" : "") &middot;
                                    @(order.IsDelivery ? "Delivery" : "Click & Collect")
                                </p>
                            </div>
                            <div class="order-row-right">
                                <span class="status-badge @statusClass">@order.Status</span>
                                <span class="order-price">£@order.TotalPrice.ToString("F2")</span>
                                <i class="bi bi-chevron-right order-chevron"></i>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>

    <div class="dash-panel" id="tab-profile">
        <div class="panel-card">
            <h2 class="panel-heading">My Profile</h2>
            <form asp-action="UpdateProfile" asp-controller="Dashboard" method="post">
                @Html.AntiForgeryToken()
                <div class="profile-grid">
                    <div class="form-group">
                        <label>First Name</label>
                        <input type="text" name="firstName" class="form-input" value="@displayName" />
                    </div>
                    <div class="form-group">
                        <label>Last Name</label>
                        <input type="text" name="lastName" class="form-input" value="" />
                    </div>
                    <div class="form-group full-width">
                        <label>Email Address</label>
                        <input type="email" name="email" class="form-input" value="@Model.Email" readonly />
                    </div>
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="tel" name="phoneNumber" class="form-input" placeholder="e.g. 07700 900 000" />
                    </div>
                    <div class="form-group">
                        <label>Default Delivery Address</label>
                        <input type="text" name="defaultDeliveryAddress" class="form-input" placeholder="e.g. 14 Orchard Lane, Cheltenham" />
                    </div>
                </div>
                <button type="submit" class="btn-primary">Save Changes</button>
            </form>
        </div>
    </div>

    <div class="dash-panel" id="tab-points">
        <div class="panel-card">
            <h2 class="panel-heading">Points & Rewards</h2>
            <div class="points-summary">
                <div class="points-stat">
                    <p class="points-stat-label">Current Balance</p>
                    <p class="points-stat-value">@Model.Points pts</p>
                </div>
                <div class="points-stat">
                    <p class="points-stat-label">Points to Next Reward</p>
                    <p class="points-stat-value">@Model.PointsToNextReward pts</p>
                </div>
            </div>
            <div class="points-history">
                @foreach (var order in Model.Orders.Where(o => o.Status != GreenField.Models.OrderStatus.Cancelled))
                {
                    int earned = (int)(order.OrderProducts.Sum(op => (op.Products?.Price ?? 0) * op.Quantity) * 10);
                    <div class="points-row">
                        <span class="points-row-label">ORD-@order.OrdersId.ToString("D4") — @order.OrderProducts.Count item@(order.OrderProducts.Count != 1 ? "s" : "")</span>
                        <span class="points-earned">+@earned pts</span>
                    </div>
                }
                <div class="points-row">
                    <span class="points-row-label">Welcome bonus</span>
                    <span class="points-earned">+50 pts</span>
                </div>
            </div>
        </div>
    </div>

    <!-- 🔴 LOGOUT BUTTON -->
    <div style="margin-top: 2rem; text-align:center;">
        <form asp-area="Identity" asp-page="/Account/Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-ghost" style="color:#dc3545; border-color:#dc3545;">
                Log Out
            </button>
        </form>
    </div>

</div>

<script>
    document.querySelectorAll('.dash-tab').forEach(tab => {
        tab.addEventListener('click', () => {
            document.querySelectorAll('.dash-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.dash-panel').forEach(p => p.classList.remove('active'));
            tab.classList.add('active');
            document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
        });
    });
</script>