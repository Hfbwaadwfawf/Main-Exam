@model GreenField.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

@Html.AntiForgeryToken()
<div class="dashboard-wrap">

    <div class="dash-header">
        <div>
            <h1 class="dash-title">Admin Dashboard</h1>
            <p class="dash-subtitle">
                @if (Model.SelectedProducer != null)
                {
                    <span>Viewing: <strong>@Model.SelectedProducer.BusinessName</strong></span>
                }
                else
                {
                    <span>All producers overview</span>
                }
            </p>
        </div>
        <div style="display:flex;align-items:center;gap:.75rem;">
            <a asp-controller="DiscountCodes" asp-action="Index" class="btn-ghost btn-sm">
                <i class="bi bi-tag-fill"></i> Discount Codes
            </a>
            <form asp-area="Identity" asp-page="/Account/Logout" method="post" style="margin:0;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-logout">
                <i class="bi bi-box-arrow-right"></i> Log Out
            </button>
        </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="producer-filter-bar">
        <label class="filter-label"><i class="bi bi-funnel-fill"></i> Filter by Producer</label>
        <div class="filter-chip-group">
            <a asp-action="Index" asp-controller="Dashboard"
               class="filter-chip @(Model.FilterProducerId == null ? "active" : "")">
                All Producers
            </a>
            @foreach (var p in Model.AllProducers)
            {
                <a asp-action="Index" asp-controller="Dashboard"
                   asp-route-filterProducerId="@p.ProducersId"
                   class="filter-chip @(Model.FilterProducerId == p.ProducersId ? "active" : "")">
                    @p.BusinessName
                </a>
            }
        </div>
    </div>

    <div class="stat-cards">
        <div class="stat-card">
            <div class="stat-card-icon-wrap">
                <i class="bi bi-box-seam-fill"></i>
            </div>
            <div class="stat-card-body">
                <p class="stat-card-label">Products</p>
                <p class="stat-card-big">@Model.Products.Count</p>
                <p class="stat-card-meta">@Model.Products.Count(p => p.IsAvailable) available</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-card-icon-wrap orders-icon">
                <i class="bi bi-receipt"></i>
            </div>
            <div class="stat-card-body">
                <p class="stat-card-label">Orders</p>
                <p class="stat-card-big">@Model.Orders.Count</p>
                <p class="stat-card-meta">@Model.Orders.Count(o => o.Status == GreenField.Models.OrderStatus.Pending || o.Status == GreenField.Models.OrderStatus.Processing) active</p>
            </div>
        </div>
        @if (Model.FilterProducerId == null)
        {
            <div class="stat-card">
                <div class="stat-card-icon-wrap producers-icon">
                    <i class="bi bi-shop"></i>
                </div>
                <div class="stat-card-body">
                    <p class="stat-card-label">Producers</p>
                    <p class="stat-card-big">@Model.AllProducers.Count</p>
                    <p class="stat-card-meta">Registered</p>
                </div>
            </div>
        }
    </div>

    <div class="dash-tabs">
        <button class="dash-tab active" data-tab="products">Products</button>
        <button class="dash-tab" data-tab="orders">Orders</button>
    </div>

    <div class="dash-panel active" id="tab-products">
        <div class="panel-card">
            <h2 class="panel-heading">
                Products
                @if (Model.SelectedProducer != null)
                {
                    <span class="heading-sub">— @Model.SelectedProducer.BusinessName</span>
                }
            </h2>
            @if (!Model.Products.Any())
            {
                <p class="empty-state">No products found.</p>
            }
            else
            {
                <div class="product-table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                @if (Model.FilterProducerId == null)
                                {
                                    <th>Producer</th>
                                }
                                <th>Category</th>
                                <th>Price</th>
                                <th>Stock</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model.Products.OrderBy(p => p.ProductName))
                            {
                                <tr>
                                    <td>
                                        <div class="product-cell">
                                            @if (!string.IsNullOrEmpty(product.Image))
                                            {
                                                <img src="@product.Image" alt="@product.ProductName" class="product-thumb" />
                                            }
                                            <span class="product-name">@product.ProductName</span>
                                        </div>
                                    </td>
                                    @if (Model.FilterProducerId == null)
                                    {
                                        <td class="producer-name-cell">
                                            @(Model.AllProducers.FirstOrDefault(p => p.ProducersId == product.ProducersId)?.BusinessName ?? "—")
                                        </td>
                                    }
                                    <td><span class="category-pill">@product.category</span></td>
                                    <td class="fw-600">£@product.Price.ToString("F2")</td>
                                    <td>@product.Stock</td>
                                    <td>
                                        @if (product.IsAvailable)
                                        {
                                            <span class="status-badge badge-delivered">Available</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge badge-cancelled">Unavailable</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="action-links">
                                            <a asp-controller="Products" asp-action="Edit" asp-route-id="@product.ProductsId" class="action-link">Edit</a>
                                            <a asp-controller="Products" asp-action="Delete" asp-route-id="@product.ProductsId" class="action-link danger">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="dash-panel" id="tab-orders">
        <div class="panel-card">
            <h2 class="panel-heading">
                Orders
                @if (Model.SelectedProducer != null)
                {
                    <span class="heading-sub">— @Model.SelectedProducer.BusinessName</span>
                }
            </h2>
            @if (!Model.Orders.Any())
            {
                <p class="empty-state">No orders found.</p>
            }
            else
            {
                <div class="order-list">
                    @foreach (var order in Model.Orders)
                    {
                        var statusClass = order.Status switch
                        {
                            GreenField.Models.OrderStatus.Delivered => "badge-delivered",
                            GreenField.Models.OrderStatus.Collected => "badge-collected",
                            GreenField.Models.OrderStatus.Processing => "badge-processing",
                            GreenField.Models.OrderStatus.Cancelled => "badge-cancelled",
                            _ => "badge-pending"
                        };
                        var relevantItems = Model.FilterProducerId.HasValue
                        ? order.OrderProducts.Where(op => op.Products?.ProducersId == Model.FilterProducerId).ToList()
                        : order.OrderProducts.ToList();
                        <div class="order-row-block">
                            <div class="order-row-top order-toggle" onclick="toggleOrder('adm-@order.OrdersId')" style="cursor:pointer;">
                                <div>
                                    <p class="order-id">ORD-@order.OrdersId.ToString("D4")</p>
                                    <p class="order-meta">
                                        @order.OrderDate.ToString("MMMM d, yyyy") &middot;
                                        @(order.IsDelivery ? "Delivery" : "Click & Collect")
                                    </p>
                                </div>
                                <div class="order-row-right">
                                    <span class="status-badge @statusClass">@order.Status</span>
                                    <span class="order-price">£@order.TotalPrice.ToString("F2")</span>
                                    <i class="bi bi-chevron-down order-chevron order-chevron-icon" id="chevron-adm-@order.OrdersId"></i>
                                </div>
                            </div>

                            <div class="order-detail-panel" id="adm-@order.OrdersId" style="display:none;">
                                <table class="table order-detail-table">
                                    <thead>
                                        <tr>
                                            <th>Product</th>
                                            @if (!Model.FilterProducerId.HasValue)
                                            {
                                                <th>Producer</th>
                                            }
                                            <th style="text-align:center;">Qty</th>
                                            <th style="text-align:right;">Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var op in relevantItems)
                                        {
                                            <tr>
                                                <td>@op.Products?.ProductName</td>
                                                @if (!Model.FilterProducerId.HasValue)
                                                {
                                                    <td class="text-muted">@(Model.AllProducers.FirstOrDefault(p => p.ProducersId == op.Products?.ProducersId)?.BusinessName ?? "—")</td>
                                                }
                                                <td style="text-align:center;">@op.Quantity</td>
                                                <td style="text-align:right;">£@(((op.Products?.Price ?? 0) * op.Quantity).ToString("F2"))</td>
                                            </tr>
                                        }
                                        @if (order.DeliveryFee > 0)
                                        {
                                            <tr>
                                                <td colspan="@(Model.FilterProducerId.HasValue ? 2 : 3)" class="text-muted">Delivery Fee</td>
                                                <td style="text-align:right;">£@order.DeliveryFee.ToString("F2")</td>
                                            </tr>
                                        }
                                        @if (order.UsedDiscount && !string.IsNullOrEmpty(order.DiscountName))
                                        {
                                            <tr>
                                                <td colspan="@(Model.FilterProducerId.HasValue ? 2 : 3)" class="text-green">Discount (@order.DiscountName)</td>
                                                <td style="text-align:right;" class="discount-amount">Applied</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="@(Model.FilterProducerId.HasValue ? 2 : 3)" class="bold">Total</td>
                                            <td style="text-align:right;" class="bold">£@order.TotalPrice.ToString("F2")</td>
                                        </tr>
                                    </tfoot>
                                </table>

                                <div class="order-detail-meta">
                                    @if (order.IsDelivery)
                                    {
                                        <p><i class="bi bi-geo-alt-fill"></i> Delivering to: <strong>@order.DeliveryAddress</strong></p>
                                    }
                                    else
                                    {
                                        <p><i class="bi bi-shop"></i> Click &amp; Collect
                                            @if (order.CollectionDate.HasValue)
                                            {
                                                <span>&mdash; @order.CollectionDate.Value.ToString("d MMM yyyy")</span>
                                            }
                                        </p>
                                    }
                                    @if (!string.IsNullOrEmpty(order.UserId))
                                    {
                                        <p class="text-muted" style="font-size:.8rem;">User ID: @order.UserId</p>
                                    }
                                </div>

                                <div class="order-detail-actions">
                                    <form asp-controller="Orders" asp-action="UpdateStatus" method="post" class="status-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderId" value="@order.OrdersId" />
                                        <label class="text-muted" style="font-size:.85rem;">Update Status:</label>
                                        <select name="status" class="status-select" onchange="this.form.submit()">
                                            @foreach (GreenField.Models.OrderStatus s in Enum.GetValues(typeof(GreenField.Models.OrderStatus)))
                                            {
                                                <option value="@s" selected="@(order.Status == s ? "selected" : null)">@s</option>
                                            }
                                        </select>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

</div>

<script>
    document.querySelectorAll('.dash-tab').forEach(tab => {
        tab.addEventListener('click', () => {
            document.querySelectorAll('.dash-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.dash-panel').forEach(p => p.classList.remove('active'));
            tab.classList.add('active');
            document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
        });
    });

    function toggleOrder(id) {
        const panel = document.getElementById(id);
        const chevron = document.getElementById('chevron-' + id);
        const isOpen = panel.style.display !== 'none';
        panel.style.display = isOpen ? 'none' : 'block';
        if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
    }
</script>