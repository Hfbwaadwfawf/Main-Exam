@model GreenField.Models.Products
@{
    ViewData["Title"] = "Delete Product";
}

<div class="static-page">
    <a asp-action="Index" class="back-link"><i class="bi bi-arrow-left"></i> Back to Store</a>
    <h1 class="page-title">Delete Product</h1>

    <div class="panel-card" style="max-width:480px;">
        <p class="text-muted mb-3">Are you sure you want to delete this product? This cannot be undone.</p>

        @if (!string.IsNullOrEmpty(Model.Image))
        {
            <img src="@Model.Image" alt="@Model.ProductName" style="width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:var(--r);margin-bottom:1rem;" />
        }

        <div class="form-group mb-1"><span class="text-sm text-muted">Product</span><p class="bold">@Model.ProductName</p></div>
        <div class="form-group mb-1"><span class="text-sm text-muted">Category</span><p>@Model.category</p></div>
        <div class="form-group mb-1"><span class="text-sm text-muted">Price</span><p>£@Model.Price.ToString("F2")</p></div>
        <div class="form-group mb-3"><span class="text-sm text-muted">Stock</span><p>@Model.Stock</p></div>

        <form asp-action="Delete" method="post" style="display:flex;gap:.75rem;">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProductsId" />
            <button type="submit" class="btn-danger">Delete</button>
            <a asp-action="Index" class="btn-ghost">Cancel</a>
        </form>
    </div>
</div>
