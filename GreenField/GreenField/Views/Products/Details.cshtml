@* product detail page — shows full info, stock status, quantity picker and add to basket *@
@model GreenField.Models.Products
@{
    ViewData["Title"] = Model.ProductName;
}

<div class="product-details-page">
    <div class="product-details-layout">

        @* left column — product image *@
        <div class="product-details-image">
            @if (!string.IsNullOrEmpty(Model.Image))
            {
                <img src="@Model.Image" alt="@Model.ProductName" />
            }
            else
            {
                <div class="img-placeholder-large">No Image</div>
            }
        </div>

        @* right column — product info, add to basket, admin actions *@
        <div class="product-details-info">

            <p class="product-details-category">@Model.category</p>
            <h1 class="product-details-name">@Model.ProductName</h1>

            @* producer name with link to filter the store by this producer *@
            @if (Model.Producers != null)
            {
                <p class="product-details-producer">
                    <i class="bi bi-shop"></i>
                    <a asp-controller="Products" asp-action="Index" asp-route-producerId="@Model.Producers.ProducersId">
                        @Model.Producers.BusinessName
                    </a>
                    @if (!string.IsNullOrEmpty(Model.Producers.BusinessBasedIn))
                    {
                        <span class="producer-location-inline">&middot; @Model.Producers.BusinessBasedIn</span>
                    }
                </p>
            }

            <p class="product-details-price">£@Model.Price.ToString("F2")</p>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="product-details-desc">@Model.Description</p>
            }

            @* stock indicator *@
            <div class="product-details-meta">
                @if (Model.IsAvailable && Model.Stock > 0)
                {
                    <span class="stock-badge in-stock">
                        <i class="bi bi-check-circle-fill"></i> In stock (@Model.Stock available)
                    </span>
                }
                else
                {
                    <span class="stock-badge out-of-stock">
                        <i class="bi bi-x-circle-fill"></i> Out of stock
                    </span>
                }
            </div>

            @* add to basket — only shown if in stock and logged in *@
            @if (Model.IsAvailable && Model.Stock > 0 && User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Baskets" asp-action="AddProduct" method="post" class="add-to-basket-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.ProductsId" />
                    <div class="qty-row">
                        @* +/- buttons call adjustQty() in JS to keep qty within stock bounds *@
                        <div class="qty-control">
                            <button type="button" class="qty-btn" onclick="adjustQty(-1)">−</button>
                            <input type="number" name="quantity" id="qtyInput" value="1" min="1" max="@Model.Stock" class="qty-input" readonly />
                            <button type="button" class="qty-btn" onclick="adjustQty(1)">+</button>
                        </div>
                        <button type="submit" class="btn-primary btn-add-basket">
                            <i class="bi bi-basket3"></i> Add to Basket
                        </button>
                    </div>
                </form>
            }
            else if (User.Identity?.IsAuthenticated == false)
            {
                @* unauthenticated users see a prompt to log in *@
                <a asp-area="Identity" asp-page="/Account/Login" class="btn-outline">Log in to purchase</a>
            }

            @* edit/delete links for admins and producers *@
            @if (User.IsInRole("Admin") || User.IsInRole("Producer"))
            {
                <div class="product-details-admin-actions">
                    <a asp-action="Edit" asp-route-id="@Model.ProductsId" class="action-link">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    @* delete is admin only — producers shouldn't hard-delete *@
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@Model.ProductsId" class="action-link danger">
                            <i class="bi bi-trash3"></i> Delete
                        </a>
                    }
                </div>
            }

            <a asp-action="Index" class="back-link">
                <i class="bi bi-arrow-left"></i> Back to Store
            </a>

        </div>
    </div>
</div>

<script>
    // clamps quantity between 1 and the max stock
    function adjustQty(delta) {
        const input = document.getElementById('qtyInput');
        const max = parseInt(input.max);
        let val = parseInt(input.value) + delta;
        val = Math.max(1, Math.min(max, val));
        input.value = val;
    }
</script>
