@model GreenField.Models.Producers
@{
    ViewData["Title"] = "Delete Producer";
}

<div class="static-page">
    <a asp-action="Index" class="back-link"><i class="bi bi-arrow-left"></i> Back to Producers</a>
    <h1 class="page-title">Delete Producer</h1>

    <div class="panel-card" style="max-width:480px;">
        <p class="text-muted mb-3">Are you sure you want to delete <strong>@Model.BusinessName</strong>? This cannot be undone.</p>

        @if (!string.IsNullOrEmpty(Model.Logo))
        {
            <img src="@Model.Logo" alt="@Model.BusinessName" style="width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:var(--r);margin-bottom:1rem;" />
        }

        <div class="form-group mb-1"><span class="text-sm text-muted">Business</span><p class="bold">@Model.BusinessName</p></div>
        @if (!string.IsNullOrEmpty(Model.BusinessBasedIn))
        {
            <div class="form-group mb-1"><span class="text-sm text-muted">Based in</span><p>@Model.BusinessBasedIn</p></div>
        }
        <div class="form-group mb-3"><span class="text-sm text-muted">Description</span><p>@Model.BusinessDescription</p></div>

        <form asp-action="Delete" method="post" style="display:flex;gap:.75rem;">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProducersId" />
            <button type="submit" class="btn-danger">Delete</button>
            <a asp-action="Index" class="btn-ghost">Cancel</a>
        </form>
    </div>
</div>
