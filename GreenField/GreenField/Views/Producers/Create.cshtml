@model GreenField.Models.Producers
@{
    ViewData["Title"] = "Add Producer";
}

<div class="static-page">
    <a asp-action="Index" class="back-link"><i class="bi bi-arrow-left"></i> Back to Producers</a>
    <h1 class="page-title">Add Producer</h1>

    <div class="panel-card" style="max-width:520px;">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            @* user dropdown — only shows Producer-role accounts *@
            <div class="form-group mb-2">
                <label asp-for="UserId">Assign to User</label>
                <select asp-for="UserId" class="form-input" asp-items="ViewBag.UserList">
                    <option value="">— Select a Producer account —</option>
                </select>
                <span asp-validation-for="UserId" class="text-red text-sm"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="BusinessName">Business Name</label>
                <input asp-for="BusinessName" class="form-input" />
                <span asp-validation-for="BusinessName" class="text-red text-sm"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="BusinessDescription">Description (optional)</label>
                <input asp-for="BusinessDescription" class="form-input" />
            </div>
            <div class="form-group mb-2">
                <label asp-for="BusinessBasedIn">Based In (optional)</label>
                <input asp-for="BusinessBasedIn" class="form-input" placeholder="e.g. Cheltenham, Gloucestershire" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Logo">Logo URL or Path (optional)</label>
                <input asp-for="Logo" class="form-input" placeholder="e.g. /images/logo.png or https://..." />
            </div>

            <button type="submit" class="btn-primary btn-full">Add Producer</button>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
