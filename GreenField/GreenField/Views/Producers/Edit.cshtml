@model GreenField.Models.Producers
@{
    ViewData["Title"] = "Edit Producer";
}

<div class="static-page">
    <a asp-action="Index" class="back-link"><i class="bi bi-arrow-left"></i> Back to Producers</a>
    <h1 class="page-title">Edit Producer</h1>

    <div class="panel-card" style="max-width:520px;">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProducersId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            @* admins get dropdown, producers get hidden field *@
            @if (ViewBag.UserList != null)
            {
                <div class="form-group mb-2">
                    <label asp-for="UserId">Assigned User</label>
                    <select asp-for="UserId" class="form-input" asp-items="ViewBag.UserList"></select>
                    <span asp-validation-for="UserId" class="text-red text-sm"></span>
                </div>
            }
            else
            {
                <input type="hidden" asp-for="UserId" />
            }
            <div class="form-group mb-2">
                <label asp-for="BusinessName">Business Name</label>
                <input asp-for="BusinessName" class="form-input" />
                <span asp-validation-for="BusinessName" class="text-red text-sm"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="BusinessDescription">Description (optional)</label>
                <input asp-for="BusinessDescription" class="form-input" />
            </div>
            <div class="form-group mb-2">
                <label asp-for="BusinessBasedIn">Based In (optional)</label>
                <input asp-for="BusinessBasedIn" class="form-input" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Logo">Logo URL or Path (optional)</label>
                <input asp-for="Logo" class="form-input" placeholder="e.g. /images/logo.png or https://..." />
            </div>

            <button type="submit" class="btn-primary btn-full">Save Changes</button>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
