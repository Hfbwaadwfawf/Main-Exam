@model GreenField.Models.Producers
@{
    ViewData["Title"] = Model.BusinessName;
}

<div class="static-page">
    <a asp-action="Index" class="back-link"><i class="bi bi-arrow-left"></i> Back to Producers</a>

    <div class="producer-card" style="max-width:640px;margin-bottom:2rem;">
        @if (!string.IsNullOrEmpty(Model.Logo))
        {
            <div class="producer-card-image"><img src="@Model.Logo" alt="@Model.BusinessName" /></div>
        }
        <div class="producer-card-body">
            <h1 class="producer-name">@Model.BusinessName</h1>
            @if (!string.IsNullOrEmpty(Model.BusinessBasedIn))
            {
                <p class="producer-location"><i class="bi bi-geo-alt-fill"></i> @Model.BusinessBasedIn</p>
            }
            <p class="producer-desc">@Model.BusinessDescription</p>
            @if (User.IsInRole("Admin"))
            {
                <div class="action-links mt-2">
                    <a asp-action="Edit" asp-route-id="@Model.ProducersId" class="action-link">Edit</a>
                    <a asp-action="Delete" asp-route-id="@Model.ProducersId" class="action-link danger">Delete</a>
                </div>
            }
        </div>
    </div>
</div>
