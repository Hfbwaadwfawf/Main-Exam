@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="static-page">

    <div class="about-header">
        <h1 class="page-title">Privacy Policy</h1>
        <p class="page-subtitle">Last updated: January 2026</p>
    </div>

    <section class="about-section">
        <h2 class="section-title">1. Who We Are</h2>
        <div class="mission-card">
            <p>GLH (Gloucestershire Local Hub) is a local food marketplace connecting communities with independent food producers across Gloucestershire and the surrounding regions. We are committed to protecting your personal data and being transparent about how we use it.</p>
        </div>
    </section>

    <section class="about-section">
        <h2 class="section-title">2. What Data We Collect</h2>
        <div class="mission-card">
            <p>We collect the following types of personal data when you use our platform:</p>
            <div class="verify-steps" style="margin-top:1rem;">
                <div class="verify-step">
                    <span class="verify-num">1</span>
                    <div><h3>Account information</h3><p>Your email address and password when you register.</p></div>
                </div>
                <div class="verify-step">
                    <span class="verify-num">2</span>
                    <div><h3>Order information</h3><p>Delivery address, items purchased, and payment records.</p></div>
                </div>
                <div class="verify-step">
                    <span class="verify-num">3</span>
                    <div><h3>Usage data</h3><p>Pages visited, products viewed, and basket activity.</p></div>
                </div>
                <div class="verify-step">
                    <span class="verify-num">4</span>
                    <div><h3>Communications</h3><p>Any messages you send to us or to producers through the platform.</p></div>
                </div>
            </div>
        </div>
    </section>

    <section class="about-section">
        <h2 class="section-title">3. How We Use Your Data</h2>
        <div class="values-grid">
            <div class="value-card">
                <h3>Order Fulfilment</h3>
                <p>We process your data to fulfil orders, send confirmations, and keep you updated on delivery status.</p>
            </div>
            <div class="value-card">
                <h3>Account Management</h3>
                <p>Your data is used to manage your account, loyalty points, and preferences on the platform.</p>
            </div>
            <div class="value-card">
                <h3>Platform Improvement</h3>
                <p>Usage data helps us improve GLH and personalise your experience over time.</p>
            </div>
            <div class="value-card">
                <h3>Legal Obligations</h3>
                <p>We retain and process certain data where required to comply with UK law and accounting regulations.</p>
            </div>
        </div>
    </section>

    <section class="about-section">
        <h2 class="section-title">4. Who We Share Your Data With</h2>
        <div class="mission-card">
            <p>We share relevant order information (such as your name and delivery address) with the producers fulfilling your order. We do not sell your personal data to third parties. We may share data with trusted service providers who assist in operating our platform, subject to confidentiality agreements.</p>
        </div>
    </section>

    <section class="about-section">
        <h2 class="section-title">5. Data Retention</h2>
        <div class="mission-card">
            <p>We retain your account data for as long as your account is active. Order records are kept for up to 7 years for legal and accounting purposes. You may request deletion of your account and associated data at any time by contacting us.</p>
        </div>
    </section>

    <section class="about-section">
        <h2 class="section-title">6. Your Rights</h2>
        <div class="mission-card">
            <p class="mb-2">Under UK GDPR, you have the right to:</p>
            <div class="verify-steps">
                <div class="verify-step">
                    <span class="verify-num">1</span>
                    <div><h3>Access</h3><p>Request a copy of the personal data we hold about you.</p></div>
                </div>
                <div class="verify-step">
                    <span class="verify-num">2</span>
                    <div><h3>Correction</h3><p>Ask us to correct any inaccurate or incomplete data.</p></div>
                </div>
                <div class="verify-step">
                    <span class="verify-num">3</span>
                    <div><h3>Deletion</h3><p>Request that we delete your data where there is no lawful reason to keep it.</p></div>
                </div>
                <div class="verify-step">
                    <span class="verify-num">4</span>
                    <div><h3>Restriction &amp; Portability</h3><p>Object to or restrict certain processing, or receive your data in a portable format.</p></div>
                </div>
            </div>
            <p class="mt-2">To exercise any of these rights, contact us at <a href="mailto:hello@glh.co.uk" class="contact-link">hello@glh.co.uk</a>.</p>
        </div>
    </section>

    <section class="about-section">
        <h2 class="section-title">7. Cookies</h2>
        <div class="mission-card">
            <p>We use essential cookies to keep you logged in and maintain your basket session. We do not use advertising or tracking cookies. You can manage cookie preferences through your browser settings.</p>
        </div>
    </section>

    <section class="about-section">
        <h2 class="section-title">8. Contact</h2>
        <div class="contact-grid">
            <div class="contact-block">
                <p class="contact-label">Privacy Enquiries</p>
                <a href="mailto:hello@glh.co.uk" class="contact-link">hello@glh.co.uk</a>
            </div>
            <div class="contact-block">
                <p class="contact-label">Postal Address</p>
                <p>GLH, Cheltenham, Gloucestershire</p>
            </div>
        </div>
    </section>

</div>