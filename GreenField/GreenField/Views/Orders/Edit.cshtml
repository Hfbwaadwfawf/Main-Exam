@model GreenField.Models.Orders
@{
    ViewData["Title"] = "Edit Order";
}

<h1 class="page-title">Edit Order</h1>
<p class="muted">Order #@Model.OrdersId</p>

<div style="max-width:520px;">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="OrdersId" />

        <div class="form-group">
            <label asp-for="Status">Status</label>
            <select asp-for="Status" class="form-input"
                    asp-items="Html.GetEnumSelectList<GreenField.Models.OrderStatus>()"></select>
        </div>

        <div class="form-group">
            <label asp-for="IsDelivery">Delivery?</label>
            <input asp-for="IsDelivery" type="checkbox" />
        </div>

        <div class="form-group">
            <label asp-for="DeliveryAddress">Delivery Address</label>
            <input asp-for="DeliveryAddress" class="form-input" />
        </div>

        <div class="form-group">
            <label asp-for="CollectionDate">Collection / Delivery Date</label>
            <input asp-for="CollectionDate" type="datetime-local" class="form-input" />
        </div>

        <div class="form-group" style="margin-top:1.5rem; display:flex; gap:.75rem;">
            <input type="submit" value="Save Changes" class="btn-primary" />
            <a asp-action="Details" asp-route-id="@Model.OrdersId" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>