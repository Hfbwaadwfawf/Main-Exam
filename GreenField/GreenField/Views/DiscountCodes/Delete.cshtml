@model GreenField.Models.DiscountCodes
@{
    ViewData["Title"] = "Delete Code";
}

<div class="static-page">
    <a asp-action="Index" class="back-link"><i class="bi bi-arrow-left"></i> Back to Codes</a>
    <h1 class="page-title">Delete Code</h1>

    <div class="panel-card" style="max-width:480px;">
        <p class="text-muted mb-3">Are you sure you want to delete this discount code? This cannot be undone.</p>

        <div class="form-group mb-1"><span class="text-sm text-muted">Code</span><p class="bold">@Model.Code</p></div>
        <div class="form-group mb-1"><span class="text-sm text-muted">Discount</span><p>@Model.Percentage%</p></div>
        <div class="form-group mb-3">
            <span class="text-sm text-muted">Status</span>
            <p>@(Model.IsActive ? "Active" : "Inactive")</p>
        </div>

        <form asp-action="Delete" method="post" style="display:flex;gap:.75rem;">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="DiscountCodesId" />
            <button type="submit" class="btn-danger">Delete</button>
            <a asp-action="Index" class="btn-ghost">Cancel</a>
        </form>
    </div>
</div>
