@model IEnumerable<GreenField.Models.DiscountCodes>
@{
    ViewData["Title"] = "Discount Codes";
}

<div class="dashboard-wrap">

    @* header with add button *@
    <div class="dash-header">
        <div>
            <h1 class="page-title">Discount Codes</h1>
            <p class="page-subtitle">Manage active and inactive discount codes.</p>
        </div>
        <a asp-action="Create" class="btn-primary">
            <i class="bi bi-plus-lg"></i> New Code
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @* codes table *@
    <div class="panel-card">
        @if (!Model.Any())
        {
            <p class="empty-state">No discount codes yet.</p>
        }
        else
        {
            <div class="product-table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Discount</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="bold">@item.Code</td>
                                <td>@item.Percentage%</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="status-badge badge-delivered">Active</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge badge-cancelled">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="action-links">
                                        <a asp-action="Edit" asp-route-id="@item.DiscountCodesId" class="action-link">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@item.DiscountCodesId" class="action-link danger">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>
