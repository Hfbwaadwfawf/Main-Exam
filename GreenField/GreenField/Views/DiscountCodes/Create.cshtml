@model GreenField.Models.DiscountCodes
@{
    ViewData["Title"] = "New Discount Code";
}

<div class="static-page">
    <a asp-action="Index" class="back-link"><i class="bi bi-arrow-left"></i> Back to Codes</a>
    <h1 class="page-title">New Discount Code</h1>

    <div class="panel-card" style="max-width:480px;">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group mb-2">
                <label asp-for="Code">Code</label>
                <input asp-for="Code" class="form-input" placeholder="e.g. SUMMER20" />
                <span asp-validation-for="Code" class="text-red text-sm"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="Percentage">Discount %</label>
                <input asp-for="Percentage" class="form-input" type="number" min="1" max="100" />
                <span asp-validation-for="Percentage" class="text-red text-sm"></span>
            </div>

            <div class="form-group mb-3" style="flex-direction:row;align-items:center;gap:.5rem;">
                <input asp-for="IsActive" class="custom-checkbox" />
                <label asp-for="IsActive" style="font-weight:400;">Active</label>
            </div>

            <button type="submit" class="btn-primary btn-full">Create Code</button>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
