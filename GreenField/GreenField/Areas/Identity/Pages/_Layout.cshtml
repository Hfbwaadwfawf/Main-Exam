<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GreenField</title>
    @* bootstrap icons for the nav *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @* site stylesheet — includes .auth-page-wrap styles that restyle Identity's default markup *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @* stripped-down nav — no basket icon, no auth checks, just links back to the main site *@
    <nav class="site-nav">
        <a class="nav-logo" href="/">GreenField</a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/Products">Store</a>
            <a href="/Producers">Producers</a>
            <a href="/Home/About">About</a>
        </div>
        @* show log in / sign up buttons since user is not authenticated on these pages *@
        <div class="nav-right">
            <a href="/Identity/Account/Login" class="btn-ghost btn-sm">Log in</a>
            <a href="/Identity/Account/Register" class="btn-primary btn-sm">Sign up</a>
        </div>
    </nav>

    <div class="wrap">
        <main role="main" style="padding-bottom: 2rem;">
            @* auth-page-wrap applies our overrides on top of Identity's default Bootstrap markup *@
            <div class="auth-page-wrap">
                @RenderBody()
            </div>
        </main>
    </div>

    @* validation scripts needed for login/register client-side validation *@
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
