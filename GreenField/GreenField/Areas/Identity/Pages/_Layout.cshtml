<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GreenField</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="site-nav">
        <a class="nav-logo" href="/">GreenField</a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/Products">Store</a>
            <a href="/Producers">Producers</a>
            <a href="/Home/About">About</a>
        </div>
        <div class="nav-right">
            <a href="/Identity/Account/Login" class="btn-ghost btn-sm">Log in</a>
            <a href="/Identity/Account/Register" class="btn-primary btn-sm">Sign up</a>
        </div>
    </nav>

    <div class="wrap">
        <main role="main" style="padding-bottom: 2rem;">
            <div class="auth-page-wrap">
                @RenderBody()
            </div>
        </main>
    </div>

    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
