@model IEnumerable<GreenField.Models.Products>
@{
    ViewData["Title"] = "Store";
    var producers = ViewData["Producers"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var currentSearch = ViewData["CurrentSearch"]?.ToString() ?? "";
    var currentProducer = ViewData["CurrentProducer"]?.ToString() ?? "";
    var currentCategory = ViewData["CurrentCategory"]?.ToString() ?? "";
    var currentMinPrice = ViewData["CurrentMinPrice"]?.ToString() ?? "";
    var currentMaxPrice = ViewData["CurrentMaxPrice"]?.ToString() ?? "";
    var categories = Model.Select(p => p.category).Where(c => !string.IsNullOrEmpty(c)).Distinct().OrderBy(c => c).ToList();
}

@Html.AntiForgeryToken()

<div class="store-layout">

    <!-- ── Sidebar ── -->
    <aside class="store-sidebar">
        <h2 class="sidebar-heading">Filters</h2>

        <form method="get" asp-action="Index" asp-controller="Products" id="filterForm">

            <div class="filter-section">
                <p class="filter-label">SEARCH</p>
                <input type="text" name="search" class="form-input" placeholder="Search products..." value="@currentSearch" />
            </div>

            <div class="filter-section">
                <p class="filter-label">CATEGORY</p>
                <ul class="category-list">
                    <li>
                        <button type="button"
                                class="category-btn @(string.IsNullOrEmpty(currentCategory) ? "active" : "")"
                                onclick="setCategory('', this)">
                            All
                        </button>
                    </li>
                    @foreach (var cat in categories)
                    {
                        <li>
                            <button type="button"
                                    class="category-btn @(currentCategory == cat ? "active" : "")"
                                    onclick="setCategory('@cat', this)">
                                @cat
                            </button>
                        </li>
                    }
                </ul>
                <input type="hidden" name="category" id="categoryInput" value="@currentCategory" />
            </div>

            <div class="filter-section">
                <p class="filter-label">PRICE RANGE</p>
                <div class="price-range-row">
                    <input type="number" name="minPrice" class="form-input price-input" placeholder="£ Min" value="@currentMinPrice" step="0.01" min="0" />
                    <span class="price-sep">—</span>
                    <input type="number" name="maxPrice" class="form-input price-input" placeholder="£ Max" value="@currentMaxPrice" step="0.01" min="0" />
                </div>
            </div>

            <div class="filter-section">
                <p class="filter-label">PRODUCER</p>
                <ul class="producer-filter-list">
                    @if (producers != null)
                    {
                        @foreach (var p in producers)
                        {
                            <li>
                                <button type="button"
                                        class="producer-filter-btn @(currentProducer == p.Value ? "active" : "")"
                                        onclick="setProducer('@p.Value', this)">
                                    @p.Text
                                </button>
                            </li>
                        }
                    }
                </ul>
                <input type="hidden" name="producerId" id="producerInput" value="@currentProducer" />
            </div>

            <button type="submit" class="btn-primary btn-full">Apply Filters</button>
            <a asp-action="Index" asp-controller="Products" class="btn-clear">Clear all filters</a>

        </form>
    </aside>

    <!-- ── Main ── -->
    <main class="store-main">

        <div class="store-main-header">
            <div>
                <h1 class="page-title">Store</h1>
                <p class="store-count">Showing @Model.Count() product@(Model.Count() != 1 ? "s" : "")</p>
            </div>
            @if (User.IsInRole("Admin") || User.IsInRole("Producer"))
            {
                <a asp-action="Create" class="btn-primary">
                    <i class="bi bi-plus-lg"></i> Add Product
                </a>
            }
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @if (!Model.Any())
        {
            <div class="store-empty">
                <i class="bi bi-search"></i>
                <p>No products found. Try adjusting your filters.</p>
                <a asp-action="Index" asp-controller="Products" class="btn-outline">Clear filters</a>
            </div>
        }
        else
        {
            <div class="product-grid" id="productGrid">
                @foreach (var product in Model)
                {
                    <div class="product-card">
                        <a asp-action="Details" asp-route-id="@product.ProductsId" class="product-card-link">
                            <div class="product-card-image">
                                @if (!string.IsNullOrEmpty(product.Image))
                                {
                                    <img src="@product.Image" alt="@product.ProductName" />
                                }
                                else
                                {
                                    <span class="img-placeholder">Product Image</span>
                                }
                            </div>
                            <div class="product-card-body">
                                <p class="product-card-name">@product.ProductName</p>
                                <p class="product-card-producer">@product.Producers?.BusinessName</p>
                                <div class="product-card-footer">
                                    <span class="product-card-price">£@product.Price.ToString("F2")</span>
                                    <span class="product-card-category">@product.category</span>
                                </div>
                            </div>
                        </a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button class="btn-add-to-basket"
                                    onclick="addToBasket(@product.ProductsId, this)">
                                <i class="bi bi-basket3-fill"></i> Add
                            </button>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("Producer"))
                        {
                            <div class="product-card-admin">
                                <a asp-action="Edit" asp-route-id="@product.ProductsId" class="action-link">Edit</a>
                                <a asp-action="Delete" asp-route-id="@product.ProductsId" class="action-link danger">Delete</a>
                            </div>
                        }
                    </div>
                }
            </div>
        }

    </main>
</div>

@section Scripts {
    <script>
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        function setCategory(cat, btn) {
            document.getElementById('categoryInput').value = cat;
            document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }

        function setProducer(val, btn) {
            const input = document.getElementById('producerInput');
            if (input.value === val) {
                input.value = '';
                btn.classList.remove('active');
            } else {
                input.value = val;
                document.querySelectorAll('.producer-filter-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            }
        }

        async function addToBasket(productId, btn) {
            const original = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i>';

            try {
                const res = await fetch('/Baskets/AddProductAjax', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `productId=${productId}&quantity=1`
                });

                const data = await res.json();

                if (data.success) {
                    btn.innerHTML = '<i class="bi bi-check-lg"></i> Added';
                    btn.classList.add('btn-added');

                    const badge = document.querySelector('.basket-badge');
                    if (badge) {
                        badge.textContent = data.basketCount;
                    } else {
                        const basketBtn = document.querySelector('.nav-basket');
                        if (basketBtn) {
                            const span = document.createElement('span');
                            span.className = 'basket-badge';
                            span.textContent = data.basketCount;
                            basketBtn.appendChild(span);
                        }
                    }

                    setTimeout(() => {
                        btn.innerHTML = original;
                        btn.classList.remove('btn-added');
                        btn.disabled = false;
                    }, 1500);
                } else {
                    btn.innerHTML = '<i class="bi bi-x-lg"></i> ' + data.message;
                    setTimeout(() => {
                        btn.innerHTML = original;
                        btn.disabled = false;
                    }, 2000);
                }
            } catch {
                btn.innerHTML = original;
                btn.disabled = false;
            }
        }
    </script>
}