@model GreenField.Models.OrderProducts

@{
    ViewData["Title"] = "Create";
}

<h1 class="page-title">Create</h1>

<h4>OrderProducts</h4>
<hr />
<div style="display:flex;flex-direction:column;gap:.75rem;max-width:520px;">
    <div style="max-width:520px;">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ProductsId" class="control-label"></label>
                <select asp-for="ProductsId" class ="form-control" asp-items="ViewBag.ProductsId"></select>
            </div>
            <div class="form-group">
                <label asp-for="OrdersId" class="control-label"></label>
                <select asp-for="OrdersId" class ="form-control" asp-items="ViewBag.OrdersId"></select>
            </div>
            <div class="form-group">
                <label asp-for="Quantity" class="control-label"></label>
                <input asp-for="Quantity" class="form-input" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
