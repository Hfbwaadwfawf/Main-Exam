<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GLH</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="site-nav">
        <!-- Logo -->
        <a class="nav-logo" asp-area="" asp-controller="Home" asp-action="Index">GLH</a>

        <!-- Centre links -->
        <div class="nav-links">
            <a asp-area="" asp-controller="Home"      asp-action="Index">Home</a>
            <a asp-area="" asp-controller="Products"  asp-action="Index">Store</a>
            <a asp-area="" asp-controller="Producers" asp-action="Index">Producers</a>
            <a asp-area="" asp-controller="Home"      asp-action="About">About</a>
            <a asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
        </div>

        <!-- Right: basket + account -->
        <div class="nav-right">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Baskets" asp-action="Index" class="nav-basket">
                    <i class="bi bi-basket3-fill" style="font-size:1.2rem;"></i>
                    <span class="basket-badge">0</span>
                </a>
                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="nav-avatar">
                    <i class="bi bi-person-fill"></i>
                </a>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login"    class="btn btn-ghost btn-sm">Log in</a>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-sm">Sign up</a>
            }
        </div>
    </nav>

    <div class="wrap">
        <main role="main" style="padding-bottom: 2rem;">
            @RenderBody()
        </main>
    </div>

    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
