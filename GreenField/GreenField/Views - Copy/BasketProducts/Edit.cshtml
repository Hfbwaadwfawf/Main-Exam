@model GreenField.Models.BasketProducts

@{
    ViewData["Title"] = "Edit";
}

<h1 class="page-title">Edit</h1>

<h4>BasketProducts</h4>
<hr />
<div style="display:flex;flex-direction:column;gap:.75rem;max-width:520px;">
    <div style="max-width:520px;">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="BasketProductsId" />
            <div class="form-group">
                <label asp-for="BasketId" class="control-label"></label>
                <select asp-for="BasketId" class="form-input" asp-items="ViewBag.BasketId"></select>
                <span asp-validation-for="BasketId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductsId" class="control-label"></label>
                <select asp-for="ProductsId" class="form-input" asp-items="ViewBag.ProductsId"></select>
                <span asp-validation-for="ProductsId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Quantity" class="control-label"></label>
                <input asp-for="Quantity" class="form-input" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
