<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GreenField</title>
    <link rel="stylesheet" href="~/css/Styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ACCESSIBILITY PANEL -->
    <div id="accessibilityPanel" role="dialog" aria-label="Accessibility settings">
        <h6>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="5" r="2" /><path d="M12 8v8m-4-5H6m12 0h-2m-2 5-2-3-2 3" /></svg>
            Accessibility
        </h6>
        <div class="a11y-row">
            <span class="a11y-label">Text Size</span>
            <div class="a11y-controls">
                <button class="btn btn-glass btn-sm" onclick="changeTextSize(-1)" aria-label="Decrease text size">A−</button>
                <button class="btn btn-glass btn-sm" onclick="changeTextSize(0)" aria-label="Reset text size">Reset</button>
                <button class="btn btn-glass btn-sm" onclick="changeTextSize(1)" aria-label="Increase text size">A+</button>
            </div>
        </div>
        <div class="a11y-row">
            <span class="a11y-label">High Contrast</span>
            <div class="a11y-controls">
                <button class="btn btn-glass btn-sm btn-full" id="contrastBtn" onclick="toggleHighContrast()">Enable High Contrast</button>
            </div>
        </div>
        <div class="a11y-row">
            <span class="a11y-label">Reduce Motion</span>
            <div class="a11y-controls">
                <button class="btn btn-glass btn-sm btn-full" id="motionBtn" onclick="toggleReduceMotion()">Enable Reduce Motion</button>
            </div>
        </div>
        <div class="a11y-row">
            <span class="a11y-label">Text to Speech</span>
            <div class="a11y-controls">
                <button class="btn btn-secondary btn-sm" onclick="startTTS()">▶ Read Page</button>
                <button class="btn btn-danger btn-sm" onclick="stopTTS()">■ Stop</button>
            </div>
        </div>
        <div class="a11y-row" style="margin-bottom:0">
            <span class="a11y-label">Disable Visual Effects</span>
            <div class="a11y-controls">
                <button class="btn btn-glass btn-sm btn-full" id="effectsBtn" onclick="toggleEffects()">Disable Glassmorphism</button>
            </div>
        </div>
    </div>

    <!-- PAGE LAYOUT -->
    <div style="display:flex; min-height:100vh; position:relative; z-index:1;">

        <!-- SIDEBAR -->
        <aside id="sidebar">

            <!-- Logo -->
            <a asp-controller="Home" asp-action="Index" class="sidebar-logo-link">
                <div class="navbar-logo-icon">🌿</div>
                <span class="sidebar-logo-text">GreenField</span>
            </a>

            <div class="sidebar-divider"></div>

            <!-- Dark mode + accessibility -->
            <div class="navbar-actions" style="padding: 4px 12px 8px;">
                <button class="theme-toggle" id="themeToggle" title="Toggle dark mode" aria-label="Toggle dark mode">
                    <div class="theme-toggle-thumb"></div>
                </button>
                <button class="navbar-icon-btn" id="accessibilityToggle" title="Accessibility" aria-label="Accessibility settings">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <circle cx="12" cy="5" r="1.5" fill="currentColor" stroke="none" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5m0 0-3 5m3-5 3 5M9 10H7m10 0h-2" />
                    </svg>
                </button>
            </div>

            <div class="sidebar-divider"></div>

            <span class="sidebar-section-label">Menu</span>

            <a asp-controller="Home" asp-action="Index" class="sidebar-link">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                Home
            </a>
            <a asp-controller="Products" asp-action="Index" class="sidebar-link">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
                Shop
            </a>
            <a asp-controller="Producers" asp-action="Index" class="sidebar-link">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 22V12l9-9 9 9v10" /><path d="M9 22V18h6v4" /></svg>
                Producers
            </a>
            <a asp-controller="Baskets" asp-action="Index" class="sidebar-link">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /></svg>
                Basket
            </a>
            <a asp-controller="UserDashboard" asp-action="Index" class="sidebar-link">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                My Account
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="sidebar-divider"></div>
                <span class="sidebar-section-label">Admin</span>
                <a asp-controller="AdminDashboard" asp-action="Index" class="sidebar-link">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                    Dashboard
                </a>
                <a asp-controller="Products" asp-action="Index" class="sidebar-link">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" /></svg>
                    Products
                </a>
                <a asp-controller="Producers" asp-action="Index" class="sidebar-link">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                    Producers
                </a>
                <a asp-controller="Orders" asp-action="Index" class="sidebar-link">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>
                    Orders
                </a>
                <a asp-controller="DiscountCodes" asp-action="Index" class="sidebar-link">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" /><line x1="7" y1="7" x2="7.01" y2="7" /></svg>
                    Discounts
                </a>
            }

            @if (User.IsInRole("Producer"))
            {
                <div class="sidebar-divider"></div>
                <span class="sidebar-section-label">My Farm</span>
                <a asp-controller="ProducerDashboard" asp-action="Index" class="sidebar-link">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                    Dashboard
                </a>
                <a asp-controller="Products" asp-action="Index" class="sidebar-link">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" /></svg>
                    My Products
                </a>
                <a asp-controller="Orders" asp-action="Index" class="sidebar-link">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>
                    Orders
                </a>
            }

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="sidebar-divider"></div>
                <span class="sidebar-section-label">Account</span>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                    <button type="submit" class="sidebar-link" style="width:100%; background:none; border:none; cursor:pointer; text-align:left; color:var(--error);">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                        Log Out
                    </button>
                </form>
            }
            else
            {
                <div class="sidebar-divider"></div>
                <span class="sidebar-section-label">Account</span>
                <a asp-area="Identity" asp-page="/Account/Login" class="sidebar-link">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" /><polyline points="10 17 15 12 10 7" /><line x1="15" y1="12" x2="3" y2="12" /></svg>
                    Log In
                </a>
                <a asp-area="Identity" asp-page="/Account/Register" class="sidebar-link">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="8.5" cy="7" r="4" /><line x1="20" y1="8" x2="20" y2="14" /><line x1="23" y1="11" x2="17" y2="11" /></svg>
                    Register
                </a>
            }

            <div class="sidebar-spacer"></div>
            <div class="sidebar-divider"></div>

            <a asp-controller="Home" asp-action="Privacy" class="sidebar-link" style="font-size:12px;">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                Privacy Policy
            </a>
        </aside>

        <!-- MAIN CONTENT -->
        <main style="flex:1; padding:32px; overflow-x:hidden; min-width:0;" role="main">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer style="border-top:1px solid var(--glass-border); padding:20px 32px; background:var(--glass); backdrop-filter:var(--blur-sm); -webkit-backdrop-filter:var(--blur-sm); position:relative; z-index:1;">
        <div style="max-width:var(--max-width); margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
            <span class="text-secondary text-sm">© 2026 <strong style="color:var(--green);">GreenField</strong> — Supporting local producers.</span>
            <div style="display:flex; gap:16px; align-items:center;">
                <a asp-controller="Home" asp-action="Privacy" class="text-sm text-secondary">Privacy</a>
                <span class="text-tertiary text-xs">Built with care 🌿</span>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/accessibility.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>