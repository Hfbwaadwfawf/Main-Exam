@model GreenField.Models.Products

@{
    ViewData["Title"] = "Product Details";
}

<div class="container page-section">

    <div class="panel panel-body-lg">

        <div class="grid-2">

            <div>
                <img src="@Model.Image" class="card" />
            </div>

            <div>

                <h2>@Model.ProductName</h2>
                <p class="text-secondary mb">@Model.Description</p>

                <div class="mb">
                    <span class="product-card-price">£@Model.Price.ToString("0.00")</span>
                </div>

                <div class="mb">
                    <span class="badge badge-success">@Model.Stock in stock</span>
                </div>

                <div class="mb">
                    <span class="text-secondary">Producer:</span>
                    <span class="font-semibold">@Model.Producers.BusinessName</span>
                </div>

                <div class="flex-gap mt-lg">
                    <a asp-action="Edit" asp-route-id="@Model.ProductsId" class="btn btn-secondary">Edit</a>
                    <a asp-action="Index" class="btn btn-ghost">Back</a>
                </div>

            </div>
        </div>

    </div>

</div>