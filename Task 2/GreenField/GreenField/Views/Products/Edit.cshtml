@model GreenField.Models.Products

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container page-section">
    <div class="container-sm">

        <div class="mb-lg">
            <h1>Edit Product</h1>
            <p class="text-secondary">Update product details.</p>
        </div>

        <div class="panel panel-body-lg">

            <form asp-action="Edit">
                <input type="hidden" asp-for="ProductsId" />

                <div asp-validation-summary="ModelOnly" class="alert alert-error mb"></div>

                <div class="grid-2">

                    <div class="form-group">
                        <label asp-for="ProductName" class="form-label"></label>
                        <input asp-for="ProductName" class="form-input" />
                    </div>

                    <div class="form-group">
                        <label asp-for="ProducersId" class="form-label"></label>
                        <select asp-for="ProducersId" class="form-select" asp-items="ViewBag.ProducersId"></select>
                    </div>

                    <div class="form-group">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" class="form-input" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Stock" class="form-label"></label>
                        <input asp-for="Stock" class="form-input" />
                    </div>

                </div>

                <div class="form-group mt">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-textarea"></textarea>
                </div>

                <div class="form-group mt">
                    <label asp-for="Image" class="form-label"></label>
                    <input asp-for="Image" class="form-input" />
                </div>

                <div class="form-group form-check mt">
                    <label class="flex-gap-sm">
                        <input class="form-check-input" asp-for="IsAvailable" />
                        <span>Available</span>
                    </label>
                </div>

                <div class="flex-between mt-lg">
                    <a asp-action="Index" class="btn btn-ghost">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}