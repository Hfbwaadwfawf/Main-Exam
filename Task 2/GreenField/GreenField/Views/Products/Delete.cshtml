@model GreenField.Models.Products

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container page-section">
    <div class="container-sm">

        <div class="panel panel-body-lg">

            <h2 class="text-error mb">Delete Product</h2>
            <p class="text-secondary mb-lg">
                This action cannot be undone. Are you sure?
            </p>

            <div class="card card-body mb">

                <div class="flex-between">
                    <div>
                        <div class="font-semibold">@Model.ProductName</div>
                        <div class="text-secondary text-sm">@Model.Producers.BusinessName</div>
                    </div>

                    <div class="product-card-price">
                        £@Model.Price.ToString("0.00")
                    </div>
                </div>

            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="ProductsId" />

                <div class="flex-between">
                    <a asp-action="Index" class="btn btn-ghost">Cancel</a>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </div>
            </form>

        </div>

    </div>
</div>