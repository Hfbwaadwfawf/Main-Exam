@model GreenField.Models.Orders
@{
    ViewData["Title"] = "Order Details";
}

<h1>Order #@Model.OrdersId</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <h4>Order Info</h4>
        <dl class="row">
            <dt class="col-sm-4">Order Date</dt>
            <dd class="col-sm-8">@Model.OrderDate.ToString("dd MMM yyyy, HH:mm")</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@Model.Status</dd>

            <dt class="col-sm-4">Type</dt>
            <dd class="col-sm-8">@(Model.IsDelivery ? "Delivery" : "Collection")</dd>

            @if (Model.IsDelivery)
            {
                <dt class="col-sm-4">Delivery Address</dt>
                <dd class="col-sm-8">@Model.DeliveryAddress</dd>

                <dt class="col-sm-4">Delivery Fee</dt>
                <dd class="col-sm-8">£@Model.DeliveryFee.ToString("0.00")</dd>
            }
            else
            {
                <dt class="col-sm-4">Collection Date</dt>
                <dd class="col-sm-8">@Model.CollectionDate?.ToString()</dd>
            }

            @if (Model.UsedDiscount)
            {
                <dt class="col-sm-4">Discount Applied</dt>
                <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.DiscountName) ? "Loyalty Discount" : Model.DiscountName)</dd>
            }
        </dl>
    </div>

    <div class="col-md-6">
        <h4>Products</h4>
        <table class="table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Qty</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderProducts)
                {
                    <tr>
                        <td>@item.Products.ProductName</td>
                        <td>@item.Quantity</td>
                        <td>£@((item.Products.Price * item.Quantity).ToString("0.00"))</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                @if (Model.DeliveryFee > 0)
                {
                    <tr>
                        <td colspan="2">Delivery Fee</td>
                        <td>£@Model.DeliveryFee.ToString("0.00")</td>
                    </tr>
                }
                <tr>
                    <td colspan="2"><strong>Total</strong></td>
                    <td><strong>£@Model.TotalPrice.ToString("0.00")</strong></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.OrdersId" class="btn btn-secondary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>