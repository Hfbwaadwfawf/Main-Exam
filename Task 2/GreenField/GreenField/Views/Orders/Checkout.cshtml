@{
    ViewData["Title"] = "Checkout";
}

<h1>Checkout</h1>

<div class="row">
    <div class="col-md-7">
        <form method="post">
            <h4>Delivery or Collection?</h4>
            <div class="mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="IsDelivery" id="delivery" value="true" checked />
                    <label class="form-check-label" for="delivery">Delivery</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="IsDelivery" id="collection" value="false" />
                    <label class="form-check-label" for="collection">Collection</label>
                </div>
            </div>

            <div id="delivery-section" class="mb-3">
                <label class="form-label">Delivery Address</label>
                <textarea name="DeliveryAddress" class="form-control" rows="3"></textarea>
            </div>

            <div id="collection-section" class="mb-3" style="display:none">
                <label class="form-label">Collection Date</label>
                <input type="date" name="CollectionDate" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Discount Code (optional)</label>
                <input type="text" name="DiscountCodeInput" class="form-control" />
                @if (!ViewData.ModelState.IsValid)
                {
                    <span class="text-danger">@ViewData.ModelState["DiscountCodeInput"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
                }
            </div>

            <button type="submit" class="btn btn-success">Place Order</button>
            <a asp-controller="Baskets" asp-action="Index" class="btn btn-secondary">Back to Basket</a>
        </form>
    </div>

    <div class="col-md-5">
        <h4>Order Summary</h4>
        <table class="table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Qty</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in ViewBag.BasketProducts)
                {
                    <tr>
                        <td>@item.Products.ProductName</td>
                        <td>@item.Quantity</td>
                        <td>£@((item.Products.Price * item.Quantity).ToString("0.00"))</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="2">Subtotal</td>
                    <td>£@ViewBag.Subtotal.ToString("0.00")</td>
                </tr>
                @if (ViewBag.LoyaltyDiscount > 0)
                {
                    <tr>
                        <td colspan="2">Loyalty Discount (10%)</td>
                        <td>-£@ViewBag.LoyaltyDiscount.ToString("0.00")</td>
                    </tr>
                }
                <tr id="delivery-fee-row">
                    <td colspan="2">Delivery Fee</td>
                    <td>£3.99</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        const deliveryRadio = document.getElementById('delivery');
        const collectionRadio = document.getElementById('collection');
        const deliverySection = document.getElementById('delivery-section');
        const collectionSection = document.getElementById('collection-section');
        const deliveryFeeRow = document.getElementById('delivery-fee-row');

        function toggle() {
            const isDelivery = deliveryRadio.checked;
            deliverySection.style.display = isDelivery ? 'block' : 'none';
            collectionSection.style.display = isDelivery ? 'none' : 'block';
            deliveryFeeRow.style.display = isDelivery ? 'table-row' : 'none';
        }

        deliveryRadio.addEventListener('change', toggle);
        collectionRadio.addEventListener('change', toggle);
    </script>
}