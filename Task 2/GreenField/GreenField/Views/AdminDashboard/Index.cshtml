@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1>Admin Dashboard</h1>
<hr />

<form method="get" class="mb-4 d-flex align-items-center gap-3">
    <label class="form-label mb-0">Filter by Producer</label>
    <select name="producerId" class="form-select" style="max-width:260px;" onchange="this.form.submit()">
        <option value="">— All Producers —</option>
        @foreach (var p in (List<GreenField.Models.Producers>)ViewBag.Producers)
        {
            <option value="@p.ProducersId"
                selected="@(ViewBag.SelectedProducerId != null && ViewBag.SelectedProducerId == p.ProducersId ? "selected" : null)">
                @p.BusinessName
            </option>
        }
    </select>
    @if (ViewBag.SelectedProducerId != null)
    {
        <a href="/AdminDashboard" class="btn btn-outline-secondary btn-sm">Clear</a>
    }
</form>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-dark text-white border-secondary">
            <div class="card-body">
                <div class="text-muted small mb-1">Total Products</div>
                <div class="fs-4">@ViewBag.TotalProducts</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark text-white border-secondary">
            <div class="card-body">
                <div class="text-muted small mb-1">Low Stock</div>
                <div class="fs-4">@ViewBag.LowStockCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark text-white border-secondary">
            <div class="card-body">
                <div class="text-muted small mb-1">Total Orders</div>
                <div class="fs-4">@ViewBag.TotalOrders</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark text-white border-secondary">
            <div class="card-body">
                <div class="text-muted small mb-1">Total Revenue</div>
                <div class="fs-4">£@((decimal)ViewBag.TotalRevenue).ToString("0.00")</div>
            </div>
        </div>
    </div>
</div>

<h4>Products</h4>
@if (((List<GreenField.Models.Products>)ViewBag.Products).Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Producer</th>
                <th>Price</th>
                <th>Stock</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in (List<GreenField.Models.Products>)ViewBag.Products)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@(item.Producers?.BusinessName ?? "—")</td>
                    <td>£@item.Price.ToString("0.00")</td>
                    <td>
                        @if (item.Stock <= 5)
                        {
                            <span class="text-warning">@item.Stock ⚠</span>
                        }
                        else
                        {
                            @item.Stock
                        }
                    </td>
                    <td><a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductsId" class="btn btn-sm btn-outline-secondary">View</a></td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No products found.</p>
}

<h4 class="mt-4">Orders</h4>
@if (((List<GreenField.Models.Orders>)ViewBag.Orders).Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Order #</th>
                <th>Date</th>
                <th>Status</th>
                <th>Type</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in (List<GreenField.Models.Orders>)ViewBag.Orders)
            {
                <tr>
                    <td>#@order.OrdersId</td>
                    <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                    <td>@order.Status</td>
                    <td>@(order.IsDelivery ? "Delivery" : "Collection")</td>
                    <td>£@order.TotalPrice.ToString("0.00")</td>
                    <td><a asp-controller="Orders" asp-action="Details" asp-route-id="@order.OrdersId" class="btn btn-sm btn-outline-secondary">View</a></td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No orders found.</p>
}