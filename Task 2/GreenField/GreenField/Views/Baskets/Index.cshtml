@model IEnumerable<GreenField.Models.BasketProducts>
@{
    ViewData["Title"] = "My Basket";
}

<h1>My Basket</h1>

@if (!Model.Any())
{
    <p>Your basket is empty.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Subtotal</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr id="row-@item.BasketProductsId">
                    <td>@item.Products.ProductName</td>
                    <td>£@item.Products.Price.ToString("0.00")</td>
                    <td>
                        <input type="number"
                               class="quantity-input"
                               value="@item.Quantity"
                               min="1"
                               style="width:60px"
                               data-basket-products-id="@item.BasketProductsId" />
                    </td>
                    <td class="subtotal-@item.BasketProductsId">
                        £@((item.Products.Price * item.Quantity).ToString("0.00"))
                    </td>
                    <td>
                        <form asp-controller="Baskets" asp-action="Remove" method="post">
                            <input type="hidden" name="BasketProductsId" value="@item.BasketProductsId" />
                            <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3">Subtotal</td>
                <td id="subtotal">£@ViewBag.Subtotal.ToString("0.00")</td>
                <td></td>
            </tr>
            @if (ViewBag.Discount > 0)
            {
                <tr>
                    <td colspan="3">Loyalty Discount (10%)</td>
                    <td>-£@ViewBag.Discount.ToString("0.00")</td>
                    <td></td>
                </tr>
            }
            <tr>
                <td colspan="3"><strong>Total</strong></td>
                <td id="total"><strong>£@ViewBag.Total.ToString("0.00")</strong></td>
                <td></td>
            </tr>
        </tfoot>
    </table>

    <form asp-controller="Baskets" asp-action="Clear" method="post">
        <button type="submit" class="btn btn-danger">Clear Basket</button>
    </form>
    <a asp-controller="Orders" asp-action="Checkout" class="btn btn-success">Checkout</a>
}

@section Scripts {
    <script>
        let debounceTimers = {};

        document.querySelectorAll('.quantity-input').forEach(input => {
            input.addEventListener('change', function () {
                const id = this.dataset.basketProductsId;
                const quantity = this.value;

                clearTimeout(debounceTimers[id]);
                debounceTimers[id] = setTimeout(async () => {
                    const formData = new FormData();
                    formData.append('BasketProductsId', id);
                    formData.append('Quantity', quantity);

                    await fetch('/basket/update', {
                        method: 'POST',
                        body: formData
                    });

                    recalculateTotals();
                }, 500);
            });
        });

        function recalculateTotals() {
            let subtotal = 0;
            document.querySelectorAll('.quantity-input').forEach(input => {
                const id = input.dataset.basketProductsId;
                const row = document.getElementById(`row-${id}`);
                const price = parseFloat(row.querySelector('td:nth-child(2)').textContent.replace('£', ''));
                const qty = parseInt(input.value);
                const lineTotal = price * qty;
                subtotal += lineTotal;
                row.querySelector(`.subtotal-${id}`).textContent = '£' + lineTotal.toFixed(2);
            });
            document.getElementById('subtotal').textContent = '£' + subtotal.toFixed(2);
            document.querySelector('#total strong').textContent = '£' + subtotal.toFixed(2);
        }
    </script>
}